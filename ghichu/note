# Build images
docker-compose build

# Chạy tất cả services (background)
docker-compose up -d

# Xem logs
docker-compose logs -f

# Xem container đang chạy
docker ps


GIT

# Tạo và chuyển sang nhánh mới
git checkout -b ten_nhanh_moi

# Đẩy branch mới lên remote
git push -u origin "ten nhanh moi"

# 1. Xem nhánh hiện tại         
git branch

muốn merge long vào master:

bash
# Chuyển sang master
git checkout master

# Merge long vào master
git merge long

# Lấy nhánh mới từ remote về(muốn sử dụng brand của mem khác)
git fetch

# Quay lại commit cũ
git checkout <id commit>
git reset --hard <id commit>
git push origin develop --force
git push origin develop

Khi bắt đầu làm tính năng mới:
# Từ develop tạo branch mới
git checkout develop
git pull origin develop
git checkout -b feature/dang-nhap-facebook

Khi làm xong tính năng:
bash
# Đẩy code lên remote
git push origin feature/dang-nhap-facebook

# Tạo Pull Request (hoặc merge trực tiếp) để merge vào develop
git checkout develop
git pull origin develop
git merge feature/dang-nhap-facebook

# Xóa branch feature (cả local và remote)
git branch -d feature/dang-nhap-facebook          # xóa local
git push origin --delete feature/dang-nhap-facebook  # xóa remote
