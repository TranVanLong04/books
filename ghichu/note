# Build images
docker-compose build

# Chạy tất cả services (background)
docker-compose up -d

# Xem logs
docker-compose logs -f

# Xem container đang chạy
docker ps


GIT

# Tạo và chuyển sang nhánh mới
git checkout -b ten_nhanh_moi

# Đẩy branch mới lên remote
git push -u origin "ten nhanh moi"

# 1. Xem nhánh hiện tại         
git branch

muốn merge long vào master:

bash
# Chuyển sang master
git checkout master

# Merge long vào master
git merge long

# Lấy nhánh mới từ remote về(muốn sử dụng brand của mem khác)
git fetch